{
  "name": "puntos",
  "version": "1.3.7",
  "description": "Self-hosted loyalty & rewards system for Guatemala (MIT, no Twilio)",
  "type": "module",
  "main": "src/app/server.js",
  "scripts": {
    "start": "node src/app/server.js",
    "worker": "node src/app/worker.js",
    "openapi:generate": "node src/scripts/generate-openapi.mjs",
    "dev": "NODE_ENV=development node --watch src/app/server.js",
    "test": "NODE_ENV=test node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "NODE_ENV=test node --test tests/unit/*.test.js",
    "test:integration": "NODE_ENV=test node --test tests/integration/*.test.js",
    "test:watch": "NODE_ENV=test node --test --watch tests/unit/*.test.js tests/integration/*.test.js",
    "test:coverage": "NODE_ENV=test node --test --experimental-test-coverage tests/unit/*.test.js tests/integration/*.test.js",
    "typecheck": "tsc --noEmit",
    "typecheck:focused": "tsc --noEmit",
    "lint": "eslint src public tests --ext .js,.mjs,.cjs --max-warnings=0",
    "test:e2e": "bash src/scripts/run-e2e-isolated.sh",
    "test:e2e:local": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "test:e2e:visual": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test tests/e2e/visual.spec.js",
    "test:e2e:visual:update": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test tests/e2e/visual.spec.js --update-snapshots",
    "test:e2e:headed": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test --headed",
    "test:e2e:install": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium firefox",
    "test:e2e:install:deps": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install --with-deps chromium firefox",
    "ops:migrate": "node src/scripts/migrations.mjs apply",
    "ops:migrate:status": "node src/scripts/migrations.mjs status",
    "ops:migrate:doctor": "node src/scripts/migrations-doctor.mjs",
    "ops:migrate:lock": "node src/scripts/migrations-lock.mjs --write",
    "ops:migrate:lock-check": "node src/scripts/migrations-lock.mjs",
    "ops:create-app-role": "node src/scripts/create-app-role.mjs",
    "ops:security-scan": "node src/scripts/security-scan.mjs",
    "ops:perf-sanity": "node src/scripts/perf-sanity.mjs",
    "ops:load:critical": "node src/scripts/load-critical.mjs",
    "ops:alerts:check": "node src/scripts/alert-check.mjs",
    "ops:alerts:drill": "bash src/scripts/alerts-drill.sh",
    "ops:smoke": "node src/scripts/deploy-smoke.mjs",
    "ops:backup": "bash src/scripts/backup-db.sh",
    "ops:backup:verify": "node src/scripts/verify-backup.mjs",
    "ops:restore": "bash src/scripts/restore-db.sh",
    "ops:restore:drill": "bash src/scripts/restore-drill.sh",
    "ops:failure:drill": "bash src/scripts/failure-drill.sh",
    "ops:backup:retention": "bash src/scripts/backup-retention.sh --apply",
    "ops:backup:health": "bash src/scripts/backup-health.sh",
    "ops:rls-check": "node src/scripts/rls-check.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "csv-stringify": "6.5.1",
    "dotenv": "16.4.7",
    "express": "4.22.1",
    "helmet": "7.1.0",
    "jose": "6.1.3",
    "nanoid": "5.0.9",
    "node-cron": "3.0.3",
    "nodemailer": "7.0.13",
    "pg": "8.13.1",
    "pino": "9.6.0",
    "pino-http": "10.3.0",
    "prom-client": "15.1.3",
    "qrcode": "1.5.4",
    "redis": "4.6.13",
    "swagger-ui-express": "5.0.1",
    "zod": "3.25.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@anatine/zod-openapi": "2.2.8",
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.58.1",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@types/node": "25.2.0",
    "eslint": "9.39.2",
    "eslint-plugin-security": "3.0.1",
    "globals": "17.3.0",
    "typescript": "5.9.3",
    "zod-to-json-schema": "3.25.1"
  }
}
