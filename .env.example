# PuntosFieles - example environment
# Copy to .env and fill in values. In production, placeholders will FAIL FAST.

NODE_ENV=production
PORT=3001
SECRETS_DIR=/var/lib/puntos/secrets

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=puntos
DB_USER=puntos_app
DB_PASSWORD_FILE=/app/.secrets/db_password
DB_MIGRATIONS_USER=puntos_app
DB_MIGRATIONS_PASSWORD_FILE=/app/.secrets/db_migrations_password

# Security
JWT_SECRET_FILE=/app/.secrets/jwt_secret

# QR signing keys (Ed25519 PEM). Required for the core scan flow.
# Generate example:
#   openssl genpkey -algorithm Ed25519 -out qr-private.pem
#   openssl pkey -in qr-private.pem -pubout -out qr-public.pem
QR_PRIVATE_KEY_PEM_FILE=/app/.secrets/qr_private_key.pem
QR_PUBLIC_KEY_PEM_FILE=/app/.secrets/qr_public_key.pem

# Reverse proxy / HTTPS
# Set to 1 only when all inbound traffic comes through a trusted reverse proxy hop.
TRUST_PROXY=0
CORS_ORIGIN=https://puntofieles.yourdomain.com
APP_ORIGIN=https://puntofieles.yourdomain.com

# Cron / timezone
TZ=America/Guatemala
CRON_TZ=America/Guatemala
CHURN_DAYS=30
CHURN_SEND_HOUR_LOCAL=9
# Safer production default: run schema/migrations explicitly in deployment pipeline.
AUTO_APPLY_SCHEMA_EXTENSIONS=false
AUTO_APPLY_MIGRATIONS=false

# Messaging provider: dev | whatsapp | smtp | sms_gateway
MESSAGE_PROVIDER=dev

# Webhooks
WEBHOOK_TIMEOUT_MS=8000
WEBHOOK_CONCURRENCY=5
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_REQUIRE_HTTPS=true
# Optional dedicated key for encrypting webhook endpoint secrets at rest.
# If empty, the app falls back to JWT_SECRET-derived key material.
WEBHOOK_SECRET_ENC_KEY_FILE=/app/.secrets/webhook_secret_enc_key
# Optional previous keys accepted for decryption during key rotation.
# Comma-separated, old->new order does not matter.
WEBHOOK_SECRET_ENC_KEY_PREVIOUS=
# Optional allowlist: comma-separated domains (e.g. example.com, hooks.zapier.com)
WEBHOOK_ALLOWLIST=
# Require provider auth (secret or HMAC) for /public/payments/webhook/*
PAYMENT_WEBHOOK_REQUIRE_AUTH=true
# Protect /api/metrics in production (send as Bearer token or x-metrics-token)
METRICS_TOKEN_FILE=/app/.secrets/metrics_token

# Platform super admin login (for /super)
SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
# Prefer hashed secret in production:
#   node -e "import bcrypt from 'bcryptjs'; bcrypt.hash(process.argv[1], 12).then(v=>console.log(v))" "YOUR_PASSWORD"
SUPER_ADMIN_PASSWORD_HASH_FILE=/app/.secrets/super_admin_password_hash
